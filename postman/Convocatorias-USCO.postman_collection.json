            "url": { "raw": "{{baseUrl}}/api/reportes/convocatorias-categoria", "host": ["{{baseUrl}}"], "path": ["api", "reportes", "convocatorias-categoria"], "query": [{ "key": "from", "value": "2026-07-01", "description": "Opcional (yyyy-MM-dd): filtra por vigencia que cruce el rango.", "disabled": true }, { "key": "to", "value": "2026-12-31", "description": "Opcional (yyyy-MM-dd).", "disabled": true }] }
