              "mode": "raw",
              "raw": "{\n  \"name\": \"Monitorias Academicas 2026\",\n  \"description\": \"Convocatoria para monitorias academicas del periodo 2026-1\",\n  \"startDate\": \"2026-07-01\",\n  \"endDate\": \"2026-07-31\",\n  \"availableSlots\": 10,\n  \"status\": \"PUBLICADA\",\n  \"categoryIds\": [1, 3]\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/convocatorias", "host": ["{{baseUrl}}"], "path": ["api", "convocatorias"] }
          }
