          "name": "Obtener convocatoria",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/convocatorias/{{callId}}", "host": ["{{baseUrl}}"], "path": ["api", "convocatorias", "{{callId}}"] }
          }
        },
        {
          "name": "Crear convocatoria (PUBLICADA con categorias)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
