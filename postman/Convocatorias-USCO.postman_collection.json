            },
            "url": { "raw": "{{baseUrl}}/api/categorias/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "categorias", "{{categoryId}}"] }
          }
        },
        {
          "name": "Eliminar categoria",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/categorias/{{categoryId}}", "host": ["{{baseUrl}}"], "path": ["api", "categorias", "{{categoryId}}"] }
          }
        }
      ]
    },
    {
      "name": "Convocatorias",
      "item": [
        {
          "name": "Listar convocatorias",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/convocatorias", "host": ["{{baseUrl}}"], "path": ["api", "convocatorias"] }
